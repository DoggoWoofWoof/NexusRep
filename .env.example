# ── NexusRep environment ──────────────────────────────────────────────
# Copy to .env.local for local dev. The app runs fully on in-memory data
# with NO values set — every external dependency is mocked by default.

# Data layer. "memory" (default, zero-setup) | "postgres" (real embedded Postgres
# via PGlite — no external server needed). All canonical state persists.
NEXUSREP_DATA_DRIVER=memory
# Where the embedded Postgres stores its files (survives restarts). Unset = in-memory.
PGLITE_DATA_DIR=.nexusrep-data
# Managed Postgres (node-postgres). When SET, this takes precedence over the drivers above and
# persists ALL canonical state to a hosted Postgres (Neon/Supabase/Render/RDS). SSL auto-enabled
# for non-localhost. Leave BLANK for local dev (falls back to memory / embedded PGlite above).
DATABASE_URL=

# ── Logging / error tracking ──────────────────────────────────────────
# Structured logger. Level: debug | info (default) | warn | error. Format: json (one object per
# line — prod/aggregators) | pretty (dev). Default format follows NODE_ENV.
NEXUSREP_LOG_LEVEL=info
NEXUSREP_LOG_FORMAT=
# Optional error-tracking DSN. We ship NO Sentry dependency; wire a tracker via registerErrorSink()
# (lib/error-capture.ts). Unset = errors are structured-logged only (nothing leaves our infra).
NEXUSREP_SENTRY_DSN=
# Rate limiting on the public endpoints (in-process token bucket; single-instance). OPT-IN — OFF by
# default; set to 1 to enable. Currently disabled because the doctor endpoints are IP-keyed and HCPs
# share IPs (hospital/clinic NAT), so enabling as-is could 429 a legitimate doctor. Re-enable once the
# doctor endpoints are keyed by session.
NEXUSREP_RATELIMIT=0

# Vendor selection (all default to mock). See docs/VENDOR_EVAL.md.
# realtime: mock | gpt-realtime | tavus
NEXUSREP_REALTIME_PROVIDER=mock
# voice: mock | whisper-elevenlabs
NEXUSREP_VOICE_PROVIDER=mock
# avatar: mock | tavus | heygen
NEXUSREP_AVATAR_PROVIDER=mock
# crm: outbox-mock | veeva | salesforce. veeva/salesforce POST each outbox event to an HTTP intake —
# set the URL (+ optional bearer) below; without a URL they fall back to the mock.
NEXUSREP_CRM_ADAPTER=outbox-mock
NEXUSREP_CRM_WEBHOOK_URL=
NEXUSREP_CRM_WEBHOOK_TOKEN=
# Background outbox retry cadence (ms). Drains failed CRM deliveries with backoff + attempt cap.
# 0 disables the worker (E2E/tests). Default 60000.
NEXUSREP_CRM_FLUSH_INTERVAL_MS=60000
# retrieval: memory-vector | pgvector
NEXUSREP_RETRIEVAL_PROVIDER=memory-vector

# HCP audience/targeting source. "modeled" (default, built-in cardiology cohort) |
# "docnexus" (calls the hosted DocNexus advanced-search POST /api/query). Auto-uses
# docnexus when a credential below is set; else modeled — so the demo always renders.
NEXUSREP_AUDIENCE=modeled
DOCNEXUS_ADVANCED_SEARCH_URL=https://advanced-search.docnexus.ai
# One of these authenticates the advanced-search call:
# - DOCNEXUS_API_KEY -> X-Api-Key
# - DOCNEXUS_ID_TOKEN / DOCNEXUS_ID_TOKEN_FILE -> platform token cache.
#   Hosted Advanced Search currently uses the captured access token as
#   Authorization: Bearer; ID tokens fall back to x-id-token for older paths.
# - DOCNEXUS_BEARER_TOKEN -> Authorization: Bearer
DOCNEXUS_API_KEY=
DOCNEXUS_ID_TOKEN=
DOCNEXUS_ID_TOKEN_FILE=.docnexus-id-token.json
DOCNEXUS_AUTO_REFRESH_TOKEN=1
DOCNEXUS_TOKEN_REFRESH_SCRIPT=scripts/docnexus-platform-token.mjs
DOCNEXUS_TOKEN_REFRESH_TIMEOUT_MS=120000
DOCNEXUS_BEARER_TOKEN=
DOCNEXUS_PLATFORM_URL=https://platform.docnexus.ai/insights
DOCNEXUS_PLATFORM_EMAIL=
DOCNEXUS_PLATFORM_PASSWORD=
# embeddings: auto (neural model, falls back to lexical) | neural | lexical.
# Neural uses a local model (Transformers.js) downloaded once on first use. Hugging Face 403s
# anonymous downloads from many datacenter IPs (e.g. Render) — set HF_TOKEN (read-only) to enable
# neural there, or leave HF_TOKEN empty and use lexical (works, just less semantic). Override the
# model with NEXUSREP_EMBEDDINGS_MODEL.
NEXUSREP_EMBEDDINGS=auto
HF_TOKEN=

# ── LLM classifier (intent/risk) ──────────────────────────────────────
# Which provider runs the live classifier: keyword (default, $0) | claude |
# openai | thinking-machines. Unconfigured providers fail safe to keyword.
NEXUSREP_CLASSIFIER=keyword
# Answer composition. Leave unset to auto-use grounded LLM composition when
# ANTHROPIC_API_KEY or OPENAI_API_KEY is present; otherwise deterministic fallback.
# Set deterministic only when you intentionally want verbatim approved blocks.
NEXUSREP_COMPOSE=
# Claude (Anthropic). Default runtime model is claude-haiku-4-5 for video latency.
# Set a larger model explicitly only when you accept slower turn-taking.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
# OpenAI (chat). Any OpenAI-compatible base URL + model.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
# Thinking Machines interaction model — only if it exposes an OpenAI-compatible
# endpoint (see docs/VENDOR_EVAL.md). Point these at it to enable comparison.
THINKING_MACHINES_BASE_URL=
THINKING_MACHINES_API_KEY=
THINKING_MACHINES_MODEL=

# ── Tavus Conversational Video Interface (video avatar + realtime) ────────────
# Set TAVUS_API_KEY to light up the real Tavus replica. The rep's replies are
# ALWAYS produced by our compliance orchestrator (Tavus persona's custom-LLM
# layer calls NEXUSREP_PUBLIC_URL/api/tavus/llm) — Tavus never free-forms answers.
TAVUS_API_KEY=
TAVUS_BASE_URL=https://tavusapi.com/v2
# Stock or custom replica ("face") the avatar renders as. Pick one from Tavus.
TAVUS_REPLICA_ID=
# Optional: reuse a pre-built persona instead of creating one per session.
TAVUS_PERSONA_ID=
# Shared secret Tavus sends to our custom-LLM endpoint (Authorization: Bearer).
TAVUS_LLM_KEY=
# Publicly-reachable URL of THIS app so Tavus can call our custom-LLM + callback.
NEXUSREP_PUBLIC_URL=http://localhost:3000
# Tavus speech stack. We pin the PAL to a known low-latency TTS config instead of
# relying on cached Tavus auto defaults. Speed is clamped to 0.8–1.2.
NEXUSREP_TAVUS_TTS_ENGINE=cartesia
NEXUSREP_TAVUS_TTS_MODEL=sonic-3
NEXUSREP_TAVUS_TTS_SPEED=1.08
# Tavus STT engine. Default "tavus-auto". For a pharma rep set "tavus-deepgram-medical" so drug/
# program names (Milvexian, LIBREXIA, Factor XIa) transcribe correctly instead of as gibberish.
# Options: tavus-auto | tavus-deepgram-medical | tavus-parakeet | tavus-soniox | tavus-whisper | tavus-advanced
NEXUSREP_TAVUS_STT=tavus-deepgram-medical

# Other vendor credentials (leave blank to stay on mocks)
ELEVENLABS_API_KEY=

# Optional "Live 3D avatar" mode (TalkingHead + HeadTTS, free, browser/WebGPU).
# Override the default sample avatar with your own free Ready Player Me GLB
# (create one at readyplayer.me — no key — and append
#  ?morphTargets=ARKit,Oculus+Visemes). Exposed to the browser, so NEXT_PUBLIC_.
NEXT_PUBLIC_NEXUSREP_AVATAR_URL=
